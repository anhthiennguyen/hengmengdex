rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isGlobalAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function membershipId(dexId) {
      return request.auth.uid + '_' + dexId;
    }

    function isDexMember(dexId) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/memberships/$(membershipId(dexId)));
    }

    function isValidDexPayload() {
      let d = request.resource.data;
      return d.name is string && d.name.size() > 0 && d.name.size() <= 60 &&
        d.color is string &&
        d.maxHp is int && d.maxHp > 0 && d.maxHp <= 1000000 &&
        d.maxAttack is int && d.maxAttack > 0 && d.maxAttack <= 1000000 &&
        d.ownerId is string;
    }

    match /dexes/{dexId} {
      allow read: if true;

      allow create: if isSignedIn() &&
        request.resource.data.ownerId == request.auth.uid &&
        isValidDexPayload();

      allow update: if isSignedIn() &&
        (resource.data.ownerId == request.auth.uid || isGlobalAdmin()) &&
        request.resource.data.ownerId == resource.data.ownerId &&
        isValidDexPayload();

      allow delete: if isSignedIn() &&
        (resource.data.ownerId == request.auth.uid || isGlobalAdmin());

      match /meng/{entryId} {
        function dex() {
          return get(/databases/$(database)/documents/dexes/$(dexId)).data;
        }
        function isDexAdmin() {
          return isSignedIn() && (dex().ownerId == request.auth.uid || isGlobalAdmin());
        }

        function isValidStage(s) {
          return s in ['basic', 'stage1', 'stage2'];
        }
        function isValidEnergyType(t) {
          return t in [
            'normal', 'fire', 'water', 'electric', 'grass', 'ice', 'fighting',
            'poison', 'ground', 'flying', 'psychic', 'bug', 'rock', 'ghost',
            'dragon', 'dark', 'steel', 'fairy', 'colorless'
          ];
        }
        function isValidAttack(a) {
          return a.name is string && a.name.size() > 0 && a.name.size() <= 40 &&
                 a.damage is int && a.damage >= 0 && a.damage <= dex().maxAttack &&
                 a.cost is list && a.cost.size() <= 5 &&
                 (a.cost.size() < 1 || isValidEnergyType(a.cost[0])) &&
                 (a.cost.size() < 2 || isValidEnergyType(a.cost[1])) &&
                 (a.cost.size() < 3 || isValidEnergyType(a.cost[2])) &&
                 (a.cost.size() < 4 || isValidEnergyType(a.cost[3])) &&
                 (a.cost.size() < 5 || isValidEnergyType(a.cost[4])) &&
                 a.text is string && a.text.size() <= 300;
        }
        function isValidAttacks(attacks) {
          return attacks is list && attacks.size() >= 1 && attacks.size() <= 4 &&
                 isValidAttack(attacks[0]) &&
                 (attacks.size() < 2 || isValidAttack(attacks[1])) &&
                 (attacks.size() < 3 || isValidAttack(attacks[2])) &&
                 (attacks.size() < 4 || isValidAttack(attacks[3]));
        }
        // Cross-doc check that `evolvesFrom` actually points at a same-dex
        // Pokemon card one evolution stage below this one. The client
        // dropdown already only offers legal targets, so this is a
        // hardening backstop, not the only line of defense.
        function priorStage(stage) {
          return stage == 'stage1' ? 'basic' : 'stage1';
        }
        function isValidEvolutionLink(stage, evolvesFrom) {
          return stage == 'basic'
            ? evolvesFrom == null
            : (evolvesFrom is string &&
               get(/databases/$(database)/documents/dexes/$(dexId)/meng/$(evolvesFrom)).data.cardType == 'meng' &&
               get(/databases/$(database)/documents/dexes/$(dexId)/meng/$(evolvesFrom)).data.stage == priorStage(stage));
        }
        function withinCaps() {
          let d = request.resource.data;
          return d.hp is int && d.hp >= 0 && d.hp <= dex().maxHp &&
                 isValidAttacks(d.attacks) &&
                 isValidStage(d.stage) &&
                 isValidEvolutionLink(d.stage, d.get('evolvesFrom', null)) &&
                 (d.get('weakness', null) == null || isValidPokemonType(d.weakness)) &&
                 (d.get('resistance', null) == null || isValidPokemonType(d.resistance)) &&
                 d.retreatCost is int && d.retreatCost >= 0 && d.retreatCost <= 4;
        }

        function isValidCondition(c) {
          return c == null ||
            (c.field in ['hp_below_percent', 'hp_above_percent'] &&
             c.value is int && c.value >= 1 && c.value <= 99);
        }
        function isValidEffect(e) {
          return (e.action in ['add_hp', 'subtract_hp', 'add_attack', 'subtract_attack'] &&
                  e.amount is int && e.amount >= 1 && e.amount <= 9999 &&
                  (e.duration == 'permanent' ||
                   (e.duration is int && e.duration >= 1 && e.duration <= 99))) ||
                 (e.action in [
                   'inflict_asleep', 'inflict_confused', 'inflict_paralyzed',
                   'inflict_burned', 'inflict_poisoned', 'cure_all_conditions'
                 ]);
        }
        function isValidRule(r) {
          return r.trigger in ['on_enter', 'on_turn_start', 'on_attack', 'on_hit', 'on_play'] &&
                 isValidCondition(r.get('condition', null)) &&
                 r.effects is list && r.effects.size() >= 1 && r.effects.size() <= 3 &&
                 isValidEffect(r.effects[0]) &&
                 (r.effects.size() < 2 || isValidEffect(r.effects[1])) &&
                 (r.effects.size() < 3 || isValidEffect(r.effects[2]));
        }
        function isValidRules(rules) {
          return rules is list && rules.size() <= 3 &&
                 (rules.size() < 1 || isValidRule(rules[0])) &&
                 (rules.size() < 2 || isValidRule(rules[1])) &&
                 (rules.size() < 3 || isValidRule(rules[2]));
        }

        function isValidPokemonType(t) {
          return t in [
            'normal', 'fire', 'water', 'electric', 'grass', 'ice', 'fighting',
            'poison', 'ground', 'flying', 'psychic', 'bug', 'rock', 'ghost',
            'dragon', 'dark', 'steel', 'fairy'
          ];
        }

        function isValidCardPayload() {
          let d = request.resource.data;
          let baseOk = d.name is string && d.name.size() > 0 && d.name.size() <= 60 &&
                       d.description is string &&
                       d.imageUrl is string &&
                       d.cardType in ['meng', 'trainer'] &&
                       isValidRules(d.get('rules', []));
          return baseOk && (
            (d.cardType == 'meng' && withinCaps() && isValidPokemonType(d.type)) ||
            (d.cardType == 'trainer' && !('hp' in d) && !('attack' in d) && !('type' in d) &&
             d.trainerType in ['item', 'supporter'])
          );
        }

        allow read: if true;

        allow create: if isSignedIn() &&
          (isDexMember(dexId) || isDexAdmin()) &&
          request.resource.data.createdBy == request.auth.uid &&
          isValidCardPayload();

        allow update: if isSignedIn() &&
          (request.auth.uid == resource.data.createdBy || isDexAdmin()) &&
          request.resource.data.createdBy == resource.data.createdBy &&
          request.resource.data.get('cardType', 'meng') == resource.data.get('cardType', 'meng') &&
          isValidCardPayload();

        allow delete: if isSignedIn() &&
          (request.auth.uid == resource.data.createdBy || isDexAdmin());
      }
    }

    match /memberships/{membershipDocId} {
      allow read: if isSignedIn() &&
        (resource.data.uid == request.auth.uid || isGlobalAdmin());

      allow create: if isSignedIn() &&
        request.resource.data.uid == request.auth.uid &&
        membershipDocId == membershipId(request.resource.data.dexId) &&
        (
          request.resource.data.role == 'member' ||
          (request.resource.data.role == 'owner' &&
           get(/databases/$(database)/documents/dexes/$(request.resource.data.dexId)).data.ownerId == request.auth.uid)
        );

      allow update: if false;

      allow delete: if isSignedIn() &&
        (resource.data.uid == request.auth.uid || isGlobalAdmin());
    }

    // Legacy top-level collection — kept read-only, locked to admin-only
    // writes, not deleted. Nothing in the app reads/writes this once Phase 6
    // (rules lockdown) lands.
    match /meng/{docId} {
      allow read: if true;
      allow create: if false;
      allow update, delete: if isGlobalAdmin();
    }

    match /admins/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }
  }
}
